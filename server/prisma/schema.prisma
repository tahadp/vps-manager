generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  username  String?    @unique
  password  String
  role      Role       @default(USER)
  status    UserStatus @default(PENDING) // Admin whitelist approval
  tier      Tier       @default(FREE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  lastLogin DateTime?
  tokenVersion Int     @default(0) // F2-1: bumps to invalidate all outstanding tokens/cookies

  telegramBotToken String?
  telegramChatId   String?

  dashboardVpsOrder   String? // JSON array of VPS IDs (user-level drag/drop order)
  chartVisibleMetrics String? // JSON array of metric keys (cpu|ram|disk|network)

  vpsList        Vps[]
  auditLogs      AuditLog[]
  alertRules     AlertRule[]
  refreshTokens  RefreshToken[]
}

model Vps {
  id            String    @id @default(uuid())
  name          String
  ipAddress     String
  os            OsType
  customOsName  String?
  status        VpsState  @default(OFFLINE)
  apiKey        String    @unique @default(uuid())
  lastHeartbeat DateTime?
  userId        String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  alertRules AlertRule[]
  settings   VpsSettings?

  @@index([userId])
  @@index([userId, status])
  @@index([status, lastHeartbeat])
  @@index([ipAddress])
}

model VpsSettings {
  id                    String   @id @default(uuid())
  vpsId                 String   @unique
  screenshotIntervalSec Int      @default(30)
  telemetryIntervalSec  Int      @default(1)
  ramDiskVisible        Boolean  @default(true)
  networkVisible        Boolean  @default(true)
  telegramEnabled       Boolean  @default(true)
  customAlertMessage    String?
  visibleCharts         String?  @default("[\"cpu\",\"ram\",\"disk\",\"network\"]")
  offlineTimeoutSec     Int      @default(60)
  offlineAlertEnabled   Boolean  @default(true)
  onlineAlertEnabled    Boolean  @default(true)
  customOfflineMessage  String?
  customOnlineMessage   String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  vps Vps @relation(fields: [vpsId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String // e.g. "RESTART", "FILE_EDIT", "SHELL_LOGIN"
  target    String // target affected
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([target])
}

enum Role {
  USER
  ADMIN
}

enum UserStatus {
  PENDING
  APPROVED
  BANNED
}

enum Tier {
  FREE
  PRO
}

enum OsType {
  LINUX
  WINDOWS
  OTHER
}

enum VpsState {
  ONLINE
  OFFLINE
  MAINTENANCE
}

model AlertRule {
  id                  String   @id @default(uuid())
  userId              String
  vpsId               String?
  metric              String? // "CPU", "RAM", "DISK", "OFFLINE" (null = offline-only rule)
  condition           String? // ">", "<"
  threshold           Float?
  durationMin         Int?
  offlineThresholdMin Int? // For OFFLINE rules: minutes offline before triggering
  customMessage       String? // Template with {{vpsName}}, {{ip}}, {{metric}}, {{value}}, {{threshold}}, {{duration}}, {{offlineMinutes}}
  action              String // "ALERT", "RESTART", "CUSTOM_SCRIPT", "ALERT_AND_RESTART"
  restartOnAlert      Boolean  @default(false)
  customScript        String?
  timeoutSeconds      Int?     @default(30) // F0-13: per-rule custom script timeout (1-3600s)
  createdAt           DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  vps  Vps? @relation(fields: [vpsId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, vpsId])
}

model HistoricalMetric {
  id        String   @id @default(uuid())
  vpsId     String
  cpu       Float
  ram       Float
  disk      Float    @default(0)
  netTx     Float    @default(0)
  netRx     Float    @default(0)
  diskTotal Float    @default(0)
  timestamp DateTime @default(now())

  @@index([vpsId, timestamp])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
