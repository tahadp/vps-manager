# Server env (committed as .env.example; real values in .env which is gitignored)
# Copy this file to .env and fill in the real values.

# Backend Server
PORT=5000
GRPC_PORT=50051

# JWT Secret (REQUIRED, >= 32 chars; generate with: openssl rand -hex 64)
JWT_SECRET=

# PostgreSQL (include connection_limit for production)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB?schema=public&connection_limit=20

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# CORS (comma-separated allowlist; no wildcards)
CORS_ORIGIN=http://localhost:3000

# Alert Engine safety
ALLOW_CUSTOM_SCRIPTS=false

# Logging
LOG_LEVEL=info

# Seed admin (used by seed scripts, NOT by the server directly)
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
