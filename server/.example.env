# Server env (committed as .example.env; real values in .env which is gitignored)
# Coolify injects all env vars at runtime via the service Environment UI.

# Coolify auto-injects PORT (e.g. 4567). The Dockerfile EXPOSE matches.
# GRPC_PORT is set via Coolify "Port Mappings" / env (50051 → 50051).
GRPC_PORT=50051

# REQUIRED, >= 32 chars; generate with: openssl rand -hex 64
JWT_SECRET=

# PostgreSQL (Coolify service hostname `postgres`, not public IP)
DATABASE_URL=postgresql://postgres:CHANGE_ME@postgres:5432/postgres?schema=public&connection_limit=20

# Redis (Coolify service hostname `redis`, not public IP)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Comma-separated allowlist. Must include the client origin or browser blocks API calls.
CORS_ORIGIN=http://wcgg0k48osoksswo08wskkkk.45.198.68.109.sslip.io

# Alert engine custom script toggle
ALLOW_CUSTOM_SCRIPTS=false

# Logging
LOG_LEVEL=info
NODE_ENV=production

# Admin seeding
# No automatic seed script ships with the server. To create the first admin,
# run a one-off Prisma create against the User model, e.g.:
#   cd server && npx prisma studio
# or insert via psql. The server itself does not read SEED_ADMIN_* env vars.
