{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "dev": "ts-node src/index.ts",
    "proto:sync": "node scripts/sync-proto.js",
    "proto:check": "node scripts/sync-proto.js --check",
    "build:tsc": "tsc",
    "build:copyproto": "node -e \"const fs=require('fs'),path=require('path');const s=path.join(__dirname,'proto'),d=path.join(__dirname,'dist','proto');fs.mkdirSync(d,{recursive:true});for(const f of fs.readdirSync(s)){fs.copyFileSync(path.join(s,f),path.join(d,f));}\"",
    "build": "prisma generate && npm run proto:sync && npm run build:tsc && npm run build:copyproto",
    "start": "node dist/index.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.1",
    "@prisma/client": "^6.19.3",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "axios": "^1.17.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "pino": "^10.3.1",
    "prisma": "^6.19.3",
    "prom-client": "^15.1.3",
    "socket.io": "^4.8.3",
    "ts-node": "^10.9.2",
    "tweetnacl": "^1.0.3",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@vitest/coverage-v8": "^4.1.8",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.19.3",
    "vitest": "^4.1.8"
  }
}
