# ==========================================
# VPS Management - Environment Configuration
# ==========================================
# Coolify injects all env vars below at runtime. The values below are
# the production defaults used by the deployed setup on
# 45.198.68.109 (sslip.io subdomain pattern).

# ----- PostgreSQL (Coolify-managed `postgres` service) -----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=postgres
# Internal connection inside the Coolify network uses the service hostname.
# The server container talks to `postgres` directly (not the public IP).
DATABASE_URL=postgresql://postgres:CHANGE_ME@postgres:5432/postgres?schema=public&connection_limit=20

# ----- Redis (Coolify-managed `redis` service) -----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ----- Server (Backend) -----
# Coolify auto-injects PORT. The Dockerfile EXPOSE both 4567 and 50051.
# PORT=4567  (set automatically by Coolify "PORT environment variable")
# GRPC_PORT=50051  (set via "Port Mappings" UI, not auto-injected)
GRPC_PORT=50051

# ----- JWT -----
# REQUIRED, >= 32 chars. Rotate with: openssl rand -hex 64
JWT_SECRET=

# ----- CORS -----
# Comma-separated allowlist of frontend origins. With Cookie+CSRF enabled (F2-1),
# the client domain MUST be listed here, otherwise the browser blocks all API calls.
CORS_ORIGIN=http://wcgg0k48osoksswo08wskkkk.45.198.68.109.sslip.io

# ----- Alert Engine safety -----
ALLOW_CUSTOM_SCRIPTS=false

# ----- Logging -----
LOG_LEVEL=info
NODE_ENV=production

# ----- Frontend (Client) build args -----
# Set as Docker build args in Coolify's "Build" section, not runtime env.
# These get inlined into the Next.js bundle at build time.
NEXT_PUBLIC_API_URL=http://x0o0ckog4cco4gco0sk8wk8w.45.198.68.109.sslip.io
NEXT_PUBLIC_RUSTDESK_URL=
