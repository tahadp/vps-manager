# ==========================================
# VPS Management - Environment Configuration
# ==========================================

# PostgreSQL Config (used by docker-compose)
POSTGRES_USER=vps_admin
POSTGRES_PASSWORD=
POSTGRES_DB=vps_management
DATABASE_URL=postgresql://vps_admin:YOUR_PASSWORD@localhost:5432/vps_management?schema=public

# Redis Config
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Backend Server Config
PORT=5000
GRPC_PORT=50051

# JWT Secret for Admin/User Sessions (REQUIRED, >= 32 chars)
JWT_SECRET=

# CORS Origin (Frontend URL; comma-separated for multiple)
CORS_ORIGIN=http://localhost:3000

# Alert Engine safety (set true only in dev)
ALLOW_CUSTOM_SCRIPTS=false

# Frontend Config
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_RUSTDESK_URL=

# Seed admin credentials (used by seed scripts)
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
