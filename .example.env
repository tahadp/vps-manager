# PostgreSQL Config
POSTGRES_USER=vps_admin
POSTGRES_PASSWORD=
POSTGRES_DB=vps_management
DATABASE_URL=postgresql://vps_admin:YOUR_PASSWORD@localhost:5432/vps_management?schema=public

# Redis Config
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Backend Server Config
PORT=5000
GRPC_PORT=50051

# JWT Secret for Admin/User Sessions
JWT_SECRET=

# Frontend Config
NEXT_PUBLIC_API_URL=
